# Document — rectangle with a wavy bottom edge. Classic "file" indicator.

shape document
    aspect      1.6
    label       0.5  0.45
    text-area   0.08 0.10   0.92 0.78
    stroke-mult 1.0

    moveto   0.00 0.00
    lineto   1.00 0.00
    lineto   1.00 0.85
    # Wavy bottom: two arcs sweeping the page edge
    curveto  0.85 1.05   0.65 0.65   0.50 0.85
    curveto  0.35 1.05   0.15 0.65   0.00 0.90
    close
end
